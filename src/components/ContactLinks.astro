---
import { Globe, Mail, Phone, type AstroComponent } from '@lucide/astro';

import GitHub from './ui/icons/GitHub.astro';
import LinkedIn from './ui/icons/LinkedIn.astro';

interface Props {
  email?: string;
  url?: string;
  phone?: string;
  profiles?: Array<{
    network: string;
    username: string;
    url: string;
  }>;
}

interface ContactLink {
  href: string;
  label: string;
  icon: AstroComponent;
  external?: boolean;
}

const { email, url, phone, profiles = [] } = Astro.props;
const icons = { GitHub, LinkedIn } as const;

function buildContactLinks(): ContactLink[] {
  const contactData = [
    url && { href: url, label: 'Website', icon: Globe, external: true },
    email && { href: `mailto:${email}`, label: 'Email', icon: Mail },
    phone && { href: `tel:${phone}`, label: 'Phone', icon: Phone },
  ];

  const links = contactData.filter(Boolean);
  profiles.forEach(({ network, url }) =>
    links.push({
      href: url,
      label: network,
      icon: icons[network as keyof typeof icons] ?? Globe,
      external: true,
    })
  );

  return links as ContactLink[];
}

const contactLinks = buildContactLinks();
---

<nav aria-label="Contact links">
  <ul class="flex items-center gap-3">
    {
      contactLinks.map(({ href, label, icon: Icon, external }) => (
        <li>
          <a
            {href}
            {...(external && { target: '_blank', rel: 'noopener noreferrer' })}
            title={label}
            aria-label={label}
            class="hover:bg-muted hover:text-foreground inline-flex size-8 items-center justify-center rounded-lg active:translate-y-px"
          >
            <Icon class="size-4" />
          </a>
        </li>
      ))
    }
  </ul>
</nav>
